# ---- x-bookmark-triage configuration -------------------------------------
# Copy to .env (gitignored) and fill in. Only the first two blocks are required.

# 1) Your X (Twitter) developer app — OAuth 2.0, type "Web App" (confidential
#    client), scopes: tweet.read users.read bookmark.read offline.access.
#    Create at https://developer.x.com  (see SETUP.md).
X_CLIENT_ID=
X_CLIENT_SECRET=

# 2) Anthropic API key for the analysis step. https://console.anthropic.com
ANTHROPIC_API_KEY=
ANALYSIS_MODEL=claude-sonnet-4-6

# 3) Where analyzed bookmarks are written. Default needs no account.
#    markdown | webhook | airtable
SINK=markdown
#   markdown sink:
MARKDOWN_PATH=./bookmarks.md
#   webhook sink:
# WEBHOOK_URL=
# WEBHOOK_AUTH_HEADER=Bearer your-token   # optional
#   airtable sink (or NocoDB/Baserow via their Airtable-style REST API):
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_ID=
# AIRTABLE_STATUS_VALUE=Open
#   Optional: write by field id instead of by name (JSON logical->fieldId map):
# AIRTABLE_FIELD_MAP={"task":"fld...","status":"fld...","priority":"fld...","category":"fld...","notes":"fld...","created_at":"fld..."}

# 4) Where run state lives. file = local JSON (default, zero infra).
#    firestore = Cloud Run / serverless.
STATE_BACKEND=file
STATE_PATH=./state.json
# Firestore-only:
# FIREBASE_PROJECT_ID=
# FIRESTORE_COLLECTION=x_bookmarks
# GOOGLE_SERVICE_ACCOUNT_KEY=   # JSON, or use ADC

# 5) Persona + categories for the analysis (who you are, what's relevant).
#    Either set PERSONA inline, or copy persona.example.txt -> persona.txt.
# PERSONA=
PERSONA_FILE=./persona.txt
CATEGORIES=Work,Personal,Learning,Finance,Health,Errand,Reference

# 6) Behavior
# BOOKMARK_FOLDER=          # only triage this X bookmark folder (empty = all)
MAX_PER_RUN=100
# CRON_SHARED_SECRET=       # required to POST /run on a deployed instance
# SETUP_SECRET=             # gate /oauth/start on a public deployment
# REDIRECT_URI=             # override OAuth callback (local: http://127.0.0.1:8080/oauth/callback)
