# Cloud Run deploy config — copy to deploy.env (gitignored) and edit.
# Only needed if you deploy to Cloud Run. To just run locally, ignore this and
# see SETUP.md (the markdown/file defaults need none of this).

GCP_PROJECT=your-gcp-project
REGION=us-central1
SERVICE=x-bookmark-triage
RUNTIME_SA=x-bookmark-triage-runtime@your-gcp-project.iam.gserviceaccount.com

# Non-secret runtime env
SINK=markdown                 # markdown | webhook | airtable
STATE_BACKEND=firestore       # serverless wants firestore (Cloud Run disk is ephemeral)
FIREBASE_PROJECT_ID=your-gcp-project
ANALYSIS_MODEL=claude-sonnet-4-6
# BOOKMARK_FOLDER=Reading     # only triage this X folder (empty = all bookmarks)
MAX_PER_RUN=100
# Quote values with spaces or commas. JSON must be single-quoted.
CATEGORIES="Work,Personal,Learning,Finance,Health,Errand,Reference"
# Airtable sink (when SINK=airtable):
# AIRTABLE_BASE_ID=app...
# AIRTABLE_TABLE_ID=tbl...
# AIRTABLE_STATUS_VALUE=Open
# AIRTABLE_FIELD_MAP='{"task":"fld...","status":"fld...","priority":"fld...","category":"fld...","notes":"fld...","created_at":"fld..."}'
# Webhook sink (when SINK=webhook):
# WEBHOOK_URL=https://...

# Secret Manager mounts: ENV_NAME=SECRET_NAME:version, comma-separated.
# Create these secrets first (see SETUP.md / bootstrap.sh).
SECRETS=X_CLIENT_ID=X_CLIENT_ID:latest,X_CLIENT_SECRET=X_CLIENT_SECRET:latest,ANTHROPIC_API_KEY=ANTHROPIC_API_KEY:latest,CRON_SHARED_SECRET=CRON_SHARED_SECRET:latest
